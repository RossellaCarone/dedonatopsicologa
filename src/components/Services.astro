---
import { services } from '../data/services';
import ServiceCard from './ServiceCard.astro';
---

<section id="servizi" class="bg-cream py-16 md:py-28 px-6 md:px-8 lg:px-28">

  <!-- Header -->
  <div class="max-w-[1200px] mx-auto mb-16 grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-16 items-end">
    <div data-reveal="fade-up" style="--reveal-delay: 40ms;">
      <p class="text-[0.72rem] font-medium tracking-[0.2em] uppercase text-warm mb-4">
        Cosa offro
      </p>
      <h2 class="font-serif font-light text-txt leading-[1.2] text-[clamp(2rem,3.5vw,3rem)]">
        I miei <em class="italic text-sage">servizi</em>
      </h2>
    </div>
    <div data-reveal="fade-up" style="--reveal-delay: 120ms;">
      <p class="text-base text-txt-mid font-light leading-[1.8]">
        Ogni percorso è unico. Offro un servizio su misura, calibrato sulle esigenze specifiche di ogni persona, online o in presenza.
      </p>
    </div>
  </div>

  <!-- Cards grid -->
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {services.map((service) => (
      <div class="fade-up h-full">
        <ServiceCard
          id={service.id}
          title={service.title}
          description={service.description}
          detail={service.detail}
          iconSvg={service.iconSvg}
          linkText={service.linkText}
          linkHref={service.linkHref}
        />
      </div>
    ))}
  </div>

</section>

<script>
  const serviceCards = Array.from(document.querySelectorAll<HTMLElement>('[data-service-card]'));

  function syncCardHeight(card: HTMLElement) {
    const front = card.querySelector<HTMLElement>('[data-service-card-face="front"]');
    const back = card.querySelector<HTMLElement>('[data-service-card-face="back"]');
    if (!front || !back) return;

    card.style.removeProperty('--service-card-height');
    const nextHeight = Math.max(front.scrollHeight, back.scrollHeight);
    card.style.setProperty('--service-card-height', `${nextHeight}px`);
  }

  function syncAllCardHeights() {
    serviceCards.forEach(syncCardHeight);
  }

  function setCardState(card: HTMLElement, flipped: boolean) {
    card.classList.toggle('is-flipped', flipped);
    const openButton = card.querySelector<HTMLButtonElement>('[data-service-card-open]');
    const front = card.querySelector<HTMLElement>('[data-service-card-face="front"]');
    const back = card.querySelector<HTMLElement>('[data-service-card-face="back"]');

    openButton?.setAttribute('aria-expanded', String(flipped));
    front?.setAttribute('aria-hidden', String(flipped));
    back?.setAttribute('aria-hidden', String(!flipped));
  }

  function closeOtherCards(currentCard: HTMLElement) {
    serviceCards.forEach((card) => {
      if (card !== currentCard) {
        setCardState(card, false);
      }
    });
  }

  serviceCards.forEach((card) => {
    const openButton = card.querySelector<HTMLButtonElement>('[data-service-card-open]');
    const closeButton = card.querySelector<HTMLButtonElement>('[data-service-card-close]');

    syncCardHeight(card);
    setCardState(card, card.classList.contains('is-flipped'));

    openButton?.addEventListener('click', () => {
      closeOtherCards(card);
      setCardState(card, true);
      requestAnimationFrame(() => closeButton?.focus());
    });

    closeButton?.addEventListener('click', () => {
      setCardState(card, false);
      requestAnimationFrame(() => openButton?.focus());
    });

    card.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape' || !card.classList.contains('is-flipped')) return;

      event.preventDefault();
      setCardState(card, false);
      requestAnimationFrame(() => openButton?.focus());
    });
  });

  const scheduleHeightSync = () => requestAnimationFrame(syncAllCardHeights);
  window.addEventListener('resize', scheduleHeightSync);
  window.addEventListener('load', scheduleHeightSync, { once: true });
  document.fonts?.ready.then(scheduleHeightSync);
</script>
