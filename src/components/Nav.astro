  </a>

  <div class="hidden md:flex items-center gap-10">
    <a href="#chi-sono" class="text-[0.8rem] font-normal tracking-[0.12em] uppercase text-txt-mid hover:text-sage transition-colors">Chi sono</a>
    <a href="#servizi" class="text-[0.8rem] font-normal tracking-[0.12em] uppercase text-txt-mid hover:text-sage transition-colors">Servizi</a>
