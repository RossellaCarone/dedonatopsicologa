---
---

<section class="min-h-screen grid grid-cols-1 md:grid-cols-2 items-center pt-16">
  <!-- Left column: text -->
  <div class="hero-text py-24 px-8 lg:pl-28 lg:pr-16">
    <div class="fade-up">
      <p class="text-[0.72rem] font-medium tracking-[0.2em] uppercase text-warm mb-6">
        Psicologa &amp; Psicoterapeuta
      </p>

      <h1 class="font-serif font-light text-txt leading-[1.1] mb-6 text-[clamp(3rem,5vw,4.5rem)]">
        Un percorso verso<br>
        il tuo <em class="italic text-sage">benessere</em><br>
        interiore
      </h1>

      <p class="text-[1.05rem] text-txt-mid font-light max-w-[440px] mb-10 leading-[1.75]">
        Sperimenta una cura empatica e mirata per le tue esigenze. Ti accompagno passo dopo passo, con un percorso cucito su misura per aiutarti a superare le difficoltà e riscoprire la tua forza interiore.
      </p>

      <div class="flex flex-row gap-4 flex-wrap">
        <a href="#contatti" class="bg-sage text-white py-3.5 px-8 text-[0.85rem] font-medium tracking-[0.08em] uppercase rounded-sm hover:bg-[#6e8370] transition-colors">
          Prenota una consulenza
        </a>
        <a href="#chi-sono" class="border border-txt/30 text-txt py-3.5 px-8 text-[0.85rem] tracking-[0.08em] uppercase rounded-sm hover:border-sage hover:text-sage transition-all">
          Scopri di più
        </a>
      </div>
    </div>
  </div>

  <!-- Right column: image -->
  <div class="hero-image hidden md:block h-screen bg-sage-pale relative overflow-hidden">
    <div class="bg-gradient-to-br from-sage-pale to-warm-light w-full h-full flex items-center justify-center">
      <img
        src="/images/monica-hero.jpg"
        alt="Monica De Donato - Psicologa"
        class="w-[70%] max-w-[380px] aspect-[3/4] object-cover rounded-sm relative z-[2]"
      />

      <!-- Decorative circles -->
      <div class="animate-float absolute top-[15%] right-[8%] w-[140px] h-[140px] border-[1.5px] border-sage/35 rounded-full"></div>
      <div class="animate-float-slow absolute top-[10%] right-[4%] w-[200px] h-[200px] border border-warm/20 rounded-full"></div>

      <!-- Experience badge -->
      <div class="absolute bottom-12 -left-8 bg-white p-4 rounded-sm shadow-[0_4px_24px_rgba(44,44,42,0.08)] max-w-[200px] z-[5]">
        <p class="font-serif text-[1.1rem] text-sage mb-1">10+ anni</p>
        <p class="text-[0.75rem] text-txt-light leading-[1.4]">di esperienza clinica nel supporto psicologico</p>
      </div>
    </div>
  </div>
</section>
