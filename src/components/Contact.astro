---
import ContactForm from './ContactForm.tsx';

const contactHighlights = [
  'Prima consulenza gratuita',
  'In studio e online',
  'Risposta entro 24 ore',
];
---

<section id="contatti" class="relative overflow-hidden bg-gradient-to-b from-[#3a483f] to-[#313d35] py-20 md:py-32 lg:py-36 px-6 md:px-8 lg:px-28 text-white">
  <div class="pointer-events-none absolute inset-0">
    <div class="ambient-orb absolute -left-16 top-10 h-40 w-40 rounded-full bg-white/6 blur-3xl"></div>
    <div class="ambient-orb-slow absolute right-0 top-1/4 h-52 w-52 rounded-full bg-sage/10 blur-3xl"></div>
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
  </div>

  <div class="relative z-[1] max-w-[1280px] mx-auto grid grid-cols-1 items-start gap-14 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1fr)] lg:gap-20 xl:gap-24">
    <!-- Left column -->
    <div class="max-w-[34rem] md:pt-4 lg:pt-8" data-reveal="fade-up">
      <p class="text-[0.72rem] font-medium tracking-[0.2em] uppercase text-warm mb-4">
        Contatti
      </p>

      <h2 class="font-serif font-light text-white leading-[1.12] text-[clamp(2.3rem,4vw,4rem)] max-w-[12ch]">
        Inizia il tuo<br><em class="italic text-sage">percorso</em> oggi
      </h2>

      <div class="w-12 h-px bg-warm mt-7 mb-8"></div>

      <p class="text-white/64 text-[1.02rem] font-light leading-[1.95] max-w-[31rem]">
        Iniziare un percorso è un atto di coraggio verso se stessi. Se senti il bisogno di un confronto o vuoi fissare un primo colloquio, puoi trovarmi qui. La prima consulenza è gratuita e senza impegno: rispondo entro 24 ore.
      </p>

      <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2">
        {contactHighlights.map((highlight, index) => (
          <div
            class:list={[
              'rounded-[1.35rem] border border-white/10 bg-white/[0.04] px-5 py-5 backdrop-blur-sm shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]',
              index === contactHighlights.length - 1 && 'sm:col-span-2',
            ]}
            data-reveal="fade-up"
            style={`--reveal-delay: ${160 + index * 90}ms;`}
          >
            <p class="text-[1rem] font-medium leading-[1.55] text-white/90">{highlight}</p>
          </div>
        ))}
      </div>

      <div class="mt-14 border-y border-white/10" data-reveal="fade-up" style="--reveal-delay: 200ms;">
        <div class="flex gap-4 items-start py-6 md:gap-5">
          <div class="mt-0.5 h-12 w-12 border border-white/10 rounded-full flex items-center justify-center shrink-0 bg-white/[0.03]">
            <svg viewBox="0 0 24 24" class="w-4 h-4 stroke-sage-light fill-none stroke-[1.5]" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.38 2 2 0 0 1 3.59 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6.29 6.29l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
          </div>
          <div>
            <p class="text-[0.72rem] font-medium tracking-[0.16em] uppercase text-white/38 mb-1.5">Telefono</p>
            <p class="text-[1rem] text-white/90">
              <a href="tel:+393388000616" class="text-white/90 hover:text-white underline-offset-2 hover:underline transition-colors">
                +39 3388000616
              </a>
            </p>
            <p class="text-[0.82rem] text-white/56 mt-1.5">Disponibile anche via WhatsApp</p>
          </div>
        </div>

        <div class="flex gap-4 items-start py-6 border-t border-white/8 md:gap-5">
          <div class="mt-0.5 h-12 w-12 border border-white/10 rounded-full flex items-center justify-center shrink-0 bg-white/[0.03]">
            <svg viewBox="0 0 24 24" class="w-4 h-4 stroke-sage-light fill-none stroke-[1.5]" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,13 2,6" />
            </svg>
          </div>
          <div>
            <p class="text-[0.72rem] font-medium tracking-[0.16em] uppercase text-white/38 mb-1.5">Email</p>
            <p class="text-[1rem] text-white/90">
              <a href="mailto:psicologadedonato@gmail.com" class="text-white/90 hover:text-white underline-offset-2 hover:underline transition-colors break-all">
                psicologadedonato@gmail.com
              </a>
            </p>
          </div>
        </div>

        <div class="flex gap-4 items-start py-6 border-t border-white/8 md:gap-5">
          <div class="mt-0.5 h-12 w-12 border border-white/10 rounded-full flex items-center justify-center shrink-0 bg-white/[0.03]">
            <svg viewBox="0 0 24 24" class="w-4 h-4 stroke-sage-light fill-none stroke-[1.5]" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
          </div>
          <div>
            <p class="text-[0.72rem] font-medium tracking-[0.16em] uppercase text-white/38 mb-1.5">Studio</p>
            <p class="text-[1rem] text-white/90 leading-[1.8]">
              Polignano a Mare (BA)<br>
              Monopoli (BA)<br>
              Consulenze online
            </p>
          </div>
        </div>

        <div class="flex gap-4 items-start py-6 border-t border-white/8 md:gap-5">
          <div class="mt-0.5 h-12 w-12 border border-white/10 rounded-full flex items-center justify-center shrink-0 bg-white/[0.03]">
            <svg viewBox="0 0 24 24" class="w-4 h-4 stroke-sage-light fill-none stroke-[1.5]" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
            </svg>
          </div>
          <div>
            <p class="text-[0.72rem] font-medium tracking-[0.16em] uppercase text-white/38 mb-1.5">Social</p>
            <div class="flex flex-wrap gap-x-6 gap-y-2 mt-0.5">
              <a href="https://www.instagram.com/psicologa_monicadedonato?igsh=Z2k1cnJhOTI5dzg5" target="_blank" rel="noopener" class="flex items-center gap-2 text-[0.95rem] text-white/88 hover:text-white transition-colors">
                <svg viewBox="0 0 24 24" class="w-5 h-5 stroke-sage-light fill-none stroke-[1.5]" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" />
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                </svg>
                Instagram
              </a>
              <a href="https://www.linkedin.com/in/monica-de-donato-a7a651257" target="_blank" rel="noopener" class="flex items-center gap-2 text-[0.95rem] text-white/88 hover:text-white transition-colors">
                <svg viewBox="0 0 24 24" class="w-5 h-5 stroke-sage-light fill-none stroke-[1.5]" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                  <rect x="2" y="9" width="4" height="12" />
                  <circle cx="4" cy="4" r="2" />
                </svg>
                LinkedIn
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right column: contact form (Preact island) -->
    <div class="md:ml-auto md:w-full md:max-w-[40rem]" data-reveal="fade-left" style="--reveal-delay: 120ms;">
      <div class="relative overflow-hidden rounded-[2rem] border border-[#d7ddd3] bg-[linear-gradient(180deg,rgba(250,248,244,0.98),rgba(255,255,255,0.94))] p-7 shadow-[0_26px_60px_rgba(18,24,20,0.18)] md:p-10 lg:p-11">
        <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(200,216,201,0.34),transparent_26%),linear-gradient(180deg,rgba(255,255,255,0.28),rgba(255,255,255,0))]"></div>
        <div class="relative z-[1] max-w-[34rem]">
          <p class="text-[0.68rem] font-medium tracking-[0.18em] uppercase text-txt-light mb-3">
            Richiedi informazioni
          </p>
          <h3 class="font-serif text-[1.9rem] md:text-[2.2rem] font-light text-txt leading-[1.12] mb-3">
            Scrivimi senza impegno
          </h3>
          <p class="text-[1rem] leading-[1.8] text-txt-mid mb-8 max-w-[30rem]">
            Compila il form oppure scegli una tipologia di consulenza per velocizzare la richiesta.
          </p>
          <ContactForm client:visible />
        </div>
      </div>
    </div>
  </div>
</section>
